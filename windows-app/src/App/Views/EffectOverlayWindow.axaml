<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FS25FfbBridge.App.ViewModels"
        x:Class="FS25FfbBridge.App.Views.EffectOverlayWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="360"
        Height="380"
        MinWidth="360"
        MinHeight="380"
        MaxWidth="360"
        MaxHeight="380"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        Topmost="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Title="FS25 FFB Overlay">
    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#F6F2E9"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="TextBlock.category">
            <Setter Property="Foreground" Value="#D5D0C6"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>
        <Style Selector="Border.shell">
            <Setter Property="Background" Value="#D8191B18"/>
            <Setter Property="BorderBrush" Value="#664B514B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="StackPanel.categoryGroup">
            <Setter Property="Spacing" Value="5"/>
        </Style>
        <Style Selector="StackPanel.lampRow">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Spacing" Value="8"/>
        </Style>
        <Style Selector="Border.lamp">
            <Setter Property="Width" Value="25"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Background" Value="#5F6861"/>
            <Setter Property="BorderBrush" Value="#9BA39C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style Selector="TextBlock.lampCode">
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>
        <Style Selector="Border.lamp.active">
            <Setter Property="Background" Value="#22C55E"/>
            <Setter Property="BorderBrush" Value="#B9F7C9"/>
        </Style>
        <Style Selector="Border.lamp.unimplemented">
            <Setter Property="Background" Value="#5A241F"/>
            <Setter Property="BorderBrush" Value="#8A3A32"/>
        </Style>
    </Window.Styles>

    <Border Classes="shell" PointerPressed="OnOverlayPointerPressed">
        <StackPanel Spacing="10">
            <StackPanel Classes="categoryGroup">
                <TextBlock Classes="category" Text="Steering Load"/>
                <StackPanel Classes="lampRow">
                    <Border Classes="lamp" Classes.active="{Binding SpeedSpringActive}" ToolTip.Tip="Steering spring">
                        <TextBlock Classes="lampCode" Text="SS"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding MechanicalFrictionActive}" ToolTip.Tip="Mechanical friction">
                        <TextBlock Classes="lampCode" Text="MF"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding ContactReliefControlsActive}" ToolTip.Tip="Contact relief controls">
                        <TextBlock Classes="lampCode" Text="CR"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Classes="categoryGroup">
                <TextBlock Classes="category" Text="Speed Stability"/>
                <StackPanel Classes="lampRow">
                    <Border Classes="lamp" Classes.active="{Binding SpeedDamperActive}" ToolTip.Tip="Road damping">
                        <TextBlock Classes="lampCode" Text="RD"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding AntiOscillationActive}" ToolTip.Tip="Anti-oscillation">
                        <TextBlock Classes="lampCode" Text="AO"/>
                    </Border>
                    <Border Classes="lamp unimplemented" ToolTip.Tip="Slew smoothing">
                        <TextBlock Classes="lampCode" Text="SM"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Classes="categoryGroup">
                <TextBlock Classes="category" Text="Surface &amp; Traction"/>
                <StackPanel Classes="lampRow">
                    <Border Classes="lamp" Classes.active="{Binding SurfaceFeedbackActive}" ToolTip.Tip="Surface feedback">
                        <TextBlock Classes="lampCode" Text="SF"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding SlipFeedbackActive}" ToolTip.Tip="Slip feedback">
                        <TextBlock Classes="lampCode" Text="SL"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding WetnessFeedbackActive}" ToolTip.Tip="Wetness">
                        <TextBlock Classes="lampCode" Text="WE"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding SteeringSlipReliefActive}" ToolTip.Tip="Steering slip relief">
                        <TextBlock Classes="lampCode" Text="SR"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Classes="categoryGroup">
                <TextBlock Classes="category" Text="Suspension &amp; Terrain"/>
                <StackPanel Classes="lampRow">
                    <Border Classes="lamp" Classes.active="{Binding BumpFeedbackActive}" ToolTip.Tip="Bump">
                        <TextBlock Classes="lampCode" Text="BU"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding LeftSuspensionHitActive}" ToolTip.Tip="Left suspension hit">
                        <TextBlock Classes="lampCode" Text="LSH"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding RightSuspensionHitActive}" ToolTip.Tip="Right suspension hit">
                        <TextBlock Classes="lampCode" Text="RSH"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding CollisionFeedbackActive}" ToolTip.Tip="Collision pulse">
                        <TextBlock Classes="lampCode" Text="CP"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding LandingFeedbackActive}" ToolTip.Tip="Landing pulse">
                        <TextBlock Classes="lampCode" Text="LP"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding TerrainRumbleActive}" ToolTip.Tip="Terrain rumble">
                        <TextBlock Classes="lampCode" Text="TR"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Classes="categoryGroup">
                <TextBlock Classes="category" Text="Load, Slope &amp; Implement"/>
                <StackPanel Classes="lampRow">
                    <Border Classes="lamp" Classes.active="{Binding LoadResistanceActive}" ToolTip.Tip="Load resistance">
                        <TextBlock Classes="lampCode" Text="LR"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding MotionFeedbackActive}" ToolTip.Tip="Motion">
                        <TextBlock Classes="lampCode" Text="MO"/>
                    </Border>
                    <Border Classes="lamp unimplemented" ToolTip.Tip="Hill standstill load">
                        <TextBlock Classes="lampCode" Text="HL"/>
                    </Border>
                    <Border Classes="lamp unimplemented" ToolTip.Tip="Side slope bias">
                        <TextBlock Classes="lampCode" Text="SB"/>
                    </Border>
                    <Border Classes="lamp unimplemented" ToolTip.Tip="Implement bias">
                        <TextBlock Classes="lampCode" Text="IB"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Classes="categoryGroup">
                <TextBlock Classes="category" Text="Engine &amp; Drivetrain"/>
                <StackPanel Classes="lampRow">
                    <Border Classes="lamp" Classes.active="{Binding RpmVibrationActive}" ToolTip.Tip="RPM vibration">
                        <TextBlock Classes="lampCode" Text="RV"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding GearShiftPulseActive}" ToolTip.Tip="Gear shift pulse">
                        <TextBlock Classes="lampCode" Text="GS"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding ClutchBrakeJerkActive}" ToolTip.Tip="Clutch/brake jerk">
                        <TextBlock Classes="lampCode" Text="CJ"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding EngineStartStopActive}" ToolTip.Tip="Engine start/stop">
                        <TextBlock Classes="lampCode" Text="ES"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding EngineUnderLoadActive}" ToolTip.Tip="Engine under load">
                        <TextBlock Classes="lampCode" Text="EL"/>
                    </Border>
                    <Border Classes="lamp" Classes.active="{Binding EngineLuggingActive}" ToolTip.Tip="Engine lugging">
                        <TextBlock Classes="lampCode" Text="LG"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
