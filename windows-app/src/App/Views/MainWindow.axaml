<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FieldForce.App.ViewModels"
        x:Class="FieldForce.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="Root"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Icon="/Assets/avalonia-logo.ico"
        Title="FieldForce App"
        Background="#F3F1EC">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F1EC"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FAF9F5"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#F0EEE8"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D8D4CA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#111612"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#5E665F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0D6F63"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#DDEBE6"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#D9E7DF"/>
        <SolidColorBrush x:Key="SelectionStrongBrush" Color="#1E6A59"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#8D1D22"/>
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#F4DADC"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#8A5A00"/>
        <SolidColorBrush x:Key="WarningSoftBrush" Color="#F3E7C2"/>
        <SolidColorBrush x:Key="DisabledTextBrush" Color="#8D928C"/>
        <SolidColorBrush x:Key="DisabledSurfaceBrush" Color="#ECE9E2"/>
        <SolidColorBrush x:Key="CodeBackgroundBrush" Color="#EEECE6"/>
        <SolidColorBrush x:Key="LogBackgroundBrush" Color="#F5F3ED"/>
        <SolidColorBrush x:Key="LogRowBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LogTextBrush" Color="#111612"/>
        <SolidColorBrush x:Key="LogMutedBrush" Color="#5E665F"/>
    </Window.Resources>
    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TextBlock.section">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="0,10,0,8"/>
            <Setter Property="Margin" Value="0,0,26,0"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TabItem TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        </Style>
        <Style Selector="TabItem:selected TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Border.badge">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,7"/>
        </Style>
        <Style Selector="Border.badge.good">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
        <Style Selector="Border.badge.warn">
            <Setter Property="Background" Value="{StaticResource WarningSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
        </Style>
        <Style Selector="Border.badge.bad">
            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
        </Style>
        <Style Selector="Border.badge TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.badge">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,7"/>
        </Style>
        <Style Selector="Button.badge.good">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
        <Style Selector="Button.badge.warn">
            <Setter Property="Background" Value="{StaticResource WarningSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
        </Style>
        <Style Selector="Button.badge TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.effectLamp">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{StaticResource DisabledTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.effectLamp.active">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="#FFF9F1"/>
        </Style>
        <Style Selector="Button.test">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FFF9F1"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Background" Value="{StaticResource DisabledSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="TextBox.mono">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{StaticResource CodeBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>
        <Style Selector="ListBox.logList">
            <Setter Property="Background" Value="{StaticResource LogBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="ListBox.logList ListBoxItem">
            <Setter Property="Background" Value="{StaticResource LogRowBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="ListBox.logList ListBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}"/>
        </Style>
        <Style Selector="ListBox.logList ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}"/>
        </Style>
        <Style Selector="ListBox.logList Expander">
            <Setter Property="Background" Value="{StaticResource LogRowBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBlock.logLine">
            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.logMuted">
            <Setter Property="Foreground" Value="{StaticResource LogMutedBrush}"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="TextBlock.output">
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="TextBlock.unavailable">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="18,14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <StackPanel Spacing="2">
                    <TextBlock Classes="title" Text="FieldForce App"/>
                    <TextBlock Text="DirectInput gameplay effects plus FS25 telemetry"
                               Foreground="#1D211F"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="1" VerticalAlignment="Center">
                    <Border Classes="badge"
                            Classes.good="{Binding IsTelemetryConnected}"
                            Classes.warn="{Binding IsTelemetryWaiting}"
                            Classes.bad="{Binding IsTelemetryLost}">
                        <TextBlock Text="{Binding TelemetryReadyText}"/>
                    </Border>
                    <Button Classes="badge"
                            Classes.good="{Binding IsFfbOperational}"
                            Classes.warn="{Binding IsFfbBlocked}"
                            MinHeight="44"
                            AutomationProperties.Name="Toggle gameplay force feedback"
                            Command="{Binding ToggleGameplayFfbCommand}">
                        <TextBlock Text="{Binding FfbReadyText}"/>
                    </Button>
                    <Border Classes="badge"
                            Classes.good="{Binding IsFfbReady}"
                            Classes.warn="{Binding IsFfbInactive}">
                        <TextBlock Text="{Binding WheelReadyText}"/>
                    </Border>
                    <Button Content="Reload"
                            MinHeight="44"
                            AutomationProperties.Name="Reload telemetry and wheel connection"
                            Command="{Binding ReloadFieldForceCommand}"/>
                    <Button Classes="danger"
                            Content="Emergency Stop"
                            MinHeight="44"
                            AutomationProperties.Name="Emergency stop all force feedback"
                            Command="{Binding StopAllEffectsCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="18">
            <TabItem Header="Dashboard">
                <ScrollViewer Margin="0,16,0,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="16">
                        <UniformGrid Columns="3" Rows="1">
                            <Border Classes="panel" Margin="0,0,10,0" MinHeight="170">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="section" Text="Wheel"/>
                                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding WheelStatus}" TextWrapping="Wrap"/>
                                    <TextBlock Classes="muted" Text="{Binding WheelReason}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding WheelNextAction}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="panel" Margin="0,0,10,0" MinHeight="170">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="section" Text="FS25 Telemetry"/>
                                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding TelemetryStatusText}" TextWrapping="Wrap"/>
                                    <TextBlock Classes="muted" Text="{Binding TelemetryReason}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding TelemetryNextAction}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="panel" MinHeight="170">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="section" Text="Force Feedback"/>
                                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding FfbStatus}" TextWrapping="Wrap"/>
                                    <TextBlock Classes="muted" Text="{Binding FfbReason}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding FfbNextAction}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="1" Classes="panel">
                            <StackPanel Spacing="14">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel>
                                        <TextBlock Classes="section" Text="Global Force Limit"/>
                                        <TextBlock Classes="muted" Text="One safety cap for every test, effect, wheel, and vehicle profile."/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <CheckBox MinHeight="44"
                                                  Content="Overlay"
                                                  AutomationProperties.Name="Show effect activation overlay window"
                                                  IsChecked="{Binding EffectOverlayEnabled, Mode=TwoWay}"/>
                                        <CheckBox MinHeight="44"
                                                  Content="Click-through"
                                                  AutomationProperties.Name="Make effect activation overlay click-through"
                                                  IsChecked="{Binding EffectOverlayClickThrough, Mode=TwoWay}"/>
                                        <Button Classes="danger"
                                                Content="Emergency Stop"
                                                MinHeight="44"
                                                AutomationProperties.Name="Emergency stop all force feedback"
                                                Command="{Binding StopAllEffectsCommand}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnDefinitions="150,*,52" RowDefinitions="44" RowSpacing="8" ColumnSpacing="10">
                                    <TextBlock Text="Force limit" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5"
                                            MinHeight="44"
                                            AutomationProperties.Name="Global force limit for all force feedback"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding GlobalForceLimitPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding GlobalForceLimitPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Expander Grid.Row="2" Header="Diagnostics">
                            <Border Classes="panel">
                                <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                    <TextBlock Classes="muted" Text="Backend"/>
                                    <TextBlock Grid.Column="1" Text="{Binding BackendStatus}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="1" Classes="muted" Text="Panic hotkey"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PanicHotkey}"/>
                                    <TextBlock Grid.Row="2" Classes="muted" Text="Active effects"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Classes="output" Text="{Binding ActiveGameplayEffects}"/>
                                    <TextBlock Grid.Row="3" Classes="muted" Text="Active category"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ActiveVehicleCategory}"/>
                                    <TextBlock Grid.Row="4" Classes="muted" Text="Outputs"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Classes="output">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}Spring {0}, damper {1}, friction {2}, vibration {3}, surface {4}, slip {5}, bump {6}">
                                                <Binding Path="SpringOutput"/>
                                                <Binding Path="DamperOutput"/>
                                                <Binding Path="FrictionOutput"/>
                                                <Binding Path="EngineVibrationOutput"/>
                                                <Binding Path="SurfaceFeedbackOutput"/>
                                                <Binding Path="SlipFeedbackOutput"/>
                                                <Binding Path="BumpFeedbackOutput"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Grid.Row="5" Classes="muted" Text="Telemetry fade"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding TelemetryFade}"/>
                                    <TextBlock Grid.Row="6" Classes="muted" Text="Config path"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Classes="output" Text="{Binding ConfigPath}"/>
                                    <TextBlock Grid.Row="7" Classes="muted" Text="Log path"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Classes="output" Text="{Binding LogPath}"/>
                                </Grid>
                            </Border>
                        </Expander>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Device">
                <Grid ColumnDefinitions="360,*" ColumnSpacing="16" Margin="0,16,0,0">
                    <Border Classes="panel">
                        <DockPanel LastChildFill="True">
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Classes="section" Text="DirectInput Devices"/>
                                    <TextBlock Classes="muted" Text="{Binding DeviceCountText}"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Scan"
                                        MinHeight="44"
                                        AutomationProperties.Name="Scan DirectInput devices"
                                        Command="{Binding ScanDevicesCommand}"/>
                            </Grid>
                            <ListBox ItemsSource="{Binding Devices}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectedItem="{Binding SelectedDevice, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="3" Margin="0,6">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding FfbStatus}" Classes="muted"/>
                                            <TextBlock Text="{Binding DeviceType}" Classes="muted"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="16">
                        <Border Classes="panel">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="section" Text="Selected Device"/>
                                <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                    <TextBlock Classes="muted" Text="Name"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedDevice.DisplayName, FallbackValue=None}"/>
                                    <TextBlock Grid.Row="1" Classes="muted" Text="Status"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDeviceStatus}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="2" Classes="muted" Text="FFB support"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DeviceCapabilityStatus}" TextWrapping="Wrap"/>
                                </Grid>
                                <Expander Header="More device details">
                                    <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" Margin="0,8,0,0">
                                        <TextBlock Classes="muted" Text="Stable ID"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedDevice.StableId, FallbackValue=None}" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="1" Classes="muted" Text="Instance GUID"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDevice.InstanceGuid, FallbackValue=None}" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="2" Classes="muted" Text="Axes / effects"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}; {1}">
                                                    <Binding Path="SelectedDevice.AxesText" FallbackValue="None"/>
                                                    <Binding Path="SelectedDevice.EffectsText" FallbackValue="None"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Classes="panel">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="section" Text="Test Effects"/>
                                <UniformGrid Columns="3" Rows="2">
                                    <Button Classes="test" Margin="0,0,8,8" MinHeight="44" Content="Spring" AutomationProperties.Name="Run spring test" Command="{Binding SpringTestCommand}"/>
                                    <Button Classes="test" Margin="0,0,8,8" MinHeight="44" Content="Damper" AutomationProperties.Name="Run damper test" Command="{Binding DamperTestCommand}"/>
                                    <Button Classes="test" Margin="0,0,0,8" MinHeight="44" Content="Vibration" AutomationProperties.Name="Run vibration test" Command="{Binding LowVibrationCommand}"/>
                                    <Button Margin="0,0,8,0" MinHeight="44" Content="Left" AutomationProperties.Name="Run constant left test" Command="{Binding ConstantLeftCommand}"/>
                                    <Button Margin="0,0,8,0" MinHeight="44" Content="Right" AutomationProperties.Name="Run constant right test" Command="{Binding ConstantRightCommand}"/>
                                    <Button Classes="danger" MinHeight="44" Content="Stop All" AutomationProperties.Name="Stop all force feedback effects" Command="{Binding StopAllEffectsCommand}"/>
                                </UniformGrid>
                                <TextBlock Classes="muted"
                                           Text="Use low limits first on old wheels. Stop All is safe to press repeatedly."/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Telemetry">
                <Grid ColumnDefinitions="1.05*,1*" RowDefinitions="Auto,*" ColumnSpacing="16" RowSpacing="16" Margin="0,16,0,0">
                    <Border Classes="panel">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="section" Text="Connection"/>
                            <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Classes="muted" Text="Status"/>
                                <TextBlock Grid.Column="1" Text="{Binding TelemetryStatus}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Classes="muted" Text="Endpoint"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TelemetryEndpoint}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Classes="muted" Text="UDP"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UdpStatus}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" Classes="muted" Text="File"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FileStatus}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="4" Classes="muted" Text="Telemetry file"/>
                                <Grid Grid.Row="4" Grid.Column="1" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                                    <TextBox Grid.ColumnSpan="3"
                                             Text="{Binding TelemetryFilePath}"
                                             IsReadOnly="True"
                                             TextWrapping="NoWrap"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                    <Button Grid.Row="1"
                                            Grid.Column="1"
                                            MinHeight="34"
                                            Content="Choose folder"
                                            Click="OnChooseTelemetryFolderClick"/>
                                    <Button Grid.Row="1"
                                            Grid.Column="2"
                                            MinHeight="34"
                                            Content="Default"
                                            Command="{Binding ResetTelemetryFolderCommand}"/>
                                </Grid>
                                <TextBlock Grid.Row="5" Classes="muted" Text="Last source"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LastPacketSource}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="6" Classes="muted" Text="Packet rate"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PacketRate}"/>
                                <TextBlock Grid.Row="7" Classes="muted" Text="Last packet age"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding LastPacketAge}"/>
                                <TextBlock Grid.Row="8" Classes="muted" Text="Parser"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding TelemetryParseStatus}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="9" Classes="muted" Text="Transport error"/>
                                <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding LastTransportError}" TextWrapping="Wrap"/>
                            </Grid>
                            <Border Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel>
                                            <TextBlock Classes="section" Text="Telemetry Capture"/>
                                            <TextBlock Classes="muted" Text="{Binding TelemetryCaptureStatus}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                MinHeight="40"
                                                Content="{Binding TelemetryCaptureButtonText}"
                                                Command="{Binding ToggleTelemetryCaptureCommand}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="96,*" RowDefinitions="Auto,Auto" RowSpacing="6">
                                        <TextBlock Classes="muted" Text="Hotkey"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TelemetryCaptureHotkey}"/>
                                        <TextBlock Grid.Row="1" Classes="muted" Text="File"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TelemetryCapturePath}" TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="panel">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="section" Text="Vehicle"/>
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Classes="muted" Text="Vehicle"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentVehicle}"/>
                                <TextBlock Grid.Row="1" Classes="muted" Text="Type"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VehicleType}"/>
                                <TextBlock Grid.Row="2" Classes="muted" Text="Category"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding VehicleCategory}"/>
                                <TextBlock Grid.Row="3" Classes="muted" Text="Game state"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GameState}"/>
                                <TextBlock Grid.Row="4" Classes="muted" Text="Speed"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SpeedKmh}"/>
                                <TextBlock Grid.Row="5" Classes="muted" Text="Steering"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SteeringAngle}"/>
                                <TextBlock Grid.Row="6" Classes="muted" Text="RPM"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Rpm}"/>
                                <TextBlock Grid.Row="7" Classes="muted" Text="Engine"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding EngineStatus}"/>
                                <TextBlock Grid.Row="8" Classes="muted" Text="Mass / total"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding MassAndTotal}"/>
                                <TextBlock Grid.Row="9" Classes="muted" Text="On field"/>
                                <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding IsOnField}"/>
                                <TextBlock Grid.Row="10" Classes="muted" Text="Surface"/>
                                <TextBlock Grid.Row="10" Grid.Column="1">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} / attr {1}">
                                            <Binding Path="SurfaceType"/>
                                            <Binding Path="SurfaceAttribute"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Grid.Row="11" Classes="muted" Text="Wetness / rain"/>
                                <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding WetnessAndRain}"/>
                                <TextBlock Grid.Row="12" Classes="muted" Text="Slip avg / max"/>
                                <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding WheelSlip}"/>
                                <TextBlock Grid.Row="13" Classes="muted" Text="Ground contact"/>
                                <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding GroundContactRatio}"/>
                                <TextBlock Grid.Row="14" Classes="muted" Text="Pitch / roll / slope"/>
                                <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding Attitude}"/>
                                <TextBlock Grid.Row="15" Classes="muted" Text="Local accel"/>
                                <TextBlock Grid.Row="15" Grid.Column="1" Text="{Binding LocalAcceleration}"/>
                                <TextBlock Grid.Row="16" Classes="muted" Text="Bump impulse"/>
                                <TextBlock Grid.Row="16" Grid.Column="1" Text="{Binding BumpImpulse}"/>
                                <TextBlock Grid.Row="17" Classes="muted" Text="Tire types"/>
                                <TextBlock Grid.Row="17" Grid.Column="1" Text="{Binding WheelTireTypes}"/>
                                <TextBlock Grid.Row="18" Classes="muted" Text="Tire profile"/>
                                <TextBlock Grid.Row="18" Grid.Column="1" Text="{Binding WheelTireProfile}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Expander Grid.Row="1" Grid.ColumnSpan="2" Header="Diagnostics">
                        <Border Classes="panel">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Classes="section" Text="Raw Packet" Margin="0,0,0,10"/>
                                <TextBox Classes="mono"
                                         Text="{Binding RawTelemetryPreview}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         MinHeight="180"/>
                            </DockPanel>
                        </Border>
                    </Expander>
                </Grid>
            </TabItem>

            <TabItem Header="Effects">
                <ScrollViewer Margin="0,16,0,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Border Classes="panel">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Classes="section" Text="Gameplay Effects"/>
                                <TextBlock Classes="muted" Text="Conservative Logitech MOMO defaults. Use the FFB button in the header to enable or disable runtime output."/>
                                <TextBlock Classes="muted">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}Runtime {0} / category {1}">
                                            <Binding Path="GameplayFfbRuntimeStatus"/>
                                            <Binding Path="ActiveVehicleCategory"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    VerticalAlignment="Center"
                                    MinHeight="44"
                                    Content="Copy strengths to all tabs"
                                    AutomationProperties.Name="Copy current effect strengths to all effect category tabs"
                                    Command="{Binding CopyEffectStrengthsToAllCategoriesCommand}"/>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <Button Content="&lt;"
                                    MinWidth="36"
                                    Padding="0,7"
                                    Command="{Binding PreviousEffectCategoryCommand}"/>
                            <ScrollViewer x:Name="EffectCategoryScroller"
                                          Grid.Column="1"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled">
                                <TabControl x:Name="EffectCategoryTabs"
                                            ItemsSource="{Binding EffectCategoryOptions}"
                                            SelectedItem="{Binding SelectedEffectCategoryOption, Mode=TwoWay}"
                                            SelectionChanged="OnEffectCategorySelectionChanged"
                                            Height="48">
                                    <TabControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </TabControl.ItemTemplate>
                                </TabControl>
                            </ScrollViewer>
                            <Button Grid.Column="2"
                                    Content="&gt;"
                                    MinWidth="36"
                                    Padding="0,7"
                                    Command="{Binding NextEffectCategoryCommand}"/>
                        </Grid>

                        <Grid ColumnDefinitions="180,*,48" ColumnSpacing="10">
                            <TextBlock Text="Global Force Limit" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5"
                                    MinHeight="44"
                                    AutomationProperties.Name="Global force limit for all profiles"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding GlobalForceLimitPercent, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding GlobalForceLimitPercent, StringFormat={}{0}%}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Spacing="18">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Steering Load"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="Steering spring" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable steering spring" IsChecked="{Binding SpeedSpringEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Steering spring strength" IsSnapToTickEnabled="True" Value="{Binding SpeedSpringStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SpeedSpringStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding SpeedSpringCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding SpringOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Mechanical friction" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="2" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable mechanical friction" IsChecked="{Binding MechanicalFrictionEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="2" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Mechanical friction strength" IsSnapToTickEnabled="True" Value="{Binding MechanicalFrictionStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding MechanicalFrictionStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding MechanicalFrictionCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output" Text="{Binding FrictionOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Contact relief controls" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Classes="muted" Text="Built in" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output muted" Text="Hidden modifier only" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Speed Stability"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="Road damping" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable road damping" IsChecked="{Binding SpeedDamperEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Road damping strength" IsSnapToTickEnabled="True" Value="{Binding SpeedDamperStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SpeedDamperStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding SpeedDamperCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding DamperOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Anti-oscillation" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Classes="muted" Text="Built in" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output muted" Text="Not tunable" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Slew smoothing" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="3" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable slew smoothing" IsChecked="{Binding SlewSmoothingEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="3" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Slew smoothing strength" IsSnapToTickEnabled="True" Value="{Binding SlewSmoothingStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding SlewSmoothingStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output" Text="{Binding DamperOutput}" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Surface &amp; Traction"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="Surface feedback" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable surface feedback" IsChecked="{Binding SurfaceFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Surface feedback strength" IsSnapToTickEnabled="True" Value="{Binding SurfaceFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SurfaceFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding SurfaceFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding SurfaceFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Slip feedback" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="2" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable slip feedback" IsChecked="{Binding SlipFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="2" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Slip feedback strength" IsSnapToTickEnabled="True" Value="{Binding SlipFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding SlipFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding SlipFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output" Text="{Binding SlipFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Wetness" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="3" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable wetness feedback" IsChecked="{Binding WetnessFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="3" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Wetness feedback strength" IsSnapToTickEnabled="True" Value="{Binding WetnessFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding WetnessFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="3" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding WetnessFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output" Text="{Binding WetnessFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Text="Steering slip relief" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Classes="muted" Text="Built in" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="5" Classes="output muted" Text="Hidden modifier only" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Suspension &amp; Terrain"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="Bump" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable bump feedback" IsChecked="{Binding BumpFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Bump feedback strength" IsSnapToTickEnabled="True" Value="{Binding BumpFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding BumpFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding BumpFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding BumpFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Suspension hit" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="2" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable suspension hit feedback" IsChecked="{Binding SuspensionHitFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="2" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Suspension hit feedback strength" IsSnapToTickEnabled="True" Value="{Binding SuspensionHitFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding SuspensionHitFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding SuspensionHitFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output" Text="{Binding BumpFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Collision pulse" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="3" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable collision feedback" IsChecked="{Binding CollisionFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="3" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Collision feedback strength" IsSnapToTickEnabled="True" Value="{Binding CollisionFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding CollisionFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="3" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding CollisionFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output" Text="{Binding BumpFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Text="Landing pulse" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="4" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable landing feedback" IsChecked="{Binding LandingFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="4" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Landing feedback strength" IsSnapToTickEnabled="True" Value="{Binding LandingFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding LandingFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="4" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding LandingFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="5" Classes="output" Text="{Binding BumpFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="5" Text="Terrain rumble" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="5" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable terrain rumble" IsChecked="{Binding TerrainRumbleEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="5" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Terrain rumble strength" IsSnapToTickEnabled="True" Value="{Binding TerrainRumbleStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="3" Text="{Binding TerrainRumbleStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="5" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding TerrainRumbleCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="5" Classes="output" Text="{Binding TerrainRumbleOutput}" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Load, Slope &amp; Implement"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="Load resistance" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable load resistance" IsChecked="{Binding LoadResistanceEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Load resistance strength" IsSnapToTickEnabled="True" Value="{Binding LoadResistanceStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding LoadResistanceStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding LoadResistanceCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding LoadFactor}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Motion" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="2" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable motion feedback" IsChecked="{Binding MotionFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="2" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Motion feedback strength" IsSnapToTickEnabled="True" Value="{Binding MotionFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding MotionFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding MotionFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output" Text="{Binding DamperOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Hill standstill load" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="3" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable hill standstill load" IsChecked="{Binding HillStandstillLoadEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="3" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Hill standstill load strength" IsSnapToTickEnabled="True" Value="{Binding HillStandstillLoadStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding HillStandstillLoadStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="3" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding HillStandstillLoadCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output" Text="{Binding LoadFactor}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Text="Side slope bias" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="4" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable side slope bias" IsChecked="{Binding SideSlopeBiasEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="4" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Side slope bias strength" IsSnapToTickEnabled="True" Value="{Binding SideSlopeBiasStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding SideSlopeBiasStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="4" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding SideSlopeBiasCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="5" Classes="output" Text="{Binding Attitude}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="5" Text="Implement bias" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="5" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable implement bias" IsChecked="{Binding ImplementBiasEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="5" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Implement bias strength" IsSnapToTickEnabled="True" Value="{Binding ImplementBiasStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="3" Text="{Binding ImplementBiasStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="5" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding ImplementBiasCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="5" Classes="output" Text="{Binding MassAndTotal}" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Engine &amp; Drivetrain"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="RPM idle" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable RPM vibration" IsChecked="{Binding EngineVibrationEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="1" MinHeight="44" AutomationProperties.Name="Idle RPM vibration strength" IsSnapToTickEnabled="True" Value="{Binding EngineIdleStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding EngineIdleStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding EngineVibrationCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding EngineVibrationOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="RPM load" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="2" Grid.Column="1" MinHeight="44" IsEnabled="False" IsChecked="{Binding EngineVibrationEnabled}"/>
                                    <Slider Grid.Row="2" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="1" MinHeight="44" AutomationProperties.Name="Loaded RPM vibration strength" IsSnapToTickEnabled="True" Value="{Binding EngineLoadStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding EngineLoadStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="4" Classes="muted" Text="Uses RPM curve" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output" Text="{Binding EngineVibrationOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Lugging boost" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="3" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="1" MinHeight="44" AutomationProperties.Name="Engine lugging boost" IsSnapToTickEnabled="True" Value="{Binding EngineLuggingBoostPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding EngineLuggingBoostPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="4" Classes="muted" Text="Low RPM load" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output muted" Text="Adds on lugging" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Text="Gear shift pulse" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="4" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable gear shift pulse" IsChecked="{Binding GearShiftPulseEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="4" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Gear shift pulse strength" IsSnapToTickEnabled="True" Value="{Binding GearShiftPulseStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding GearShiftPulseStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="4" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding GearShiftPulseCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="5" Classes="output" Text="{Binding BumpFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="5" Text="Clutch/brake jerk" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="5" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable clutch brake jerk" IsChecked="{Binding DrivetrainPulseEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="5" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Clutch brake jerk strength" IsSnapToTickEnabled="True" Value="{Binding DrivetrainPulseStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="3" Text="{Binding DrivetrainPulseStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="5" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding DrivetrainPulseCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="5" Classes="output" Text="{Binding BumpFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="6" Text="Engine start/stop" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="6" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable engine start stop pulse" IsChecked="{Binding EngineStartStopPulseEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="6" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Engine start stop pulse strength" IsSnapToTickEnabled="True" Value="{Binding EngineStartStopPulseStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="3" Text="{Binding EngineStartStopPulseStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="6" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding EngineStartStopPulseCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="5" Classes="output" Text="{Binding BumpFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="7" Text="Engine cap" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="7" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="1" MinHeight="44" AutomationProperties.Name="Engine drivetrain max" IsSnapToTickEnabled="True" Value="{Binding EngineDrivetrainMaxPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="7" Grid.Column="3" Text="{Binding EngineDrivetrainMaxPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="7" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="7" Grid.Column="5" Classes="output muted" Text="Max engine output" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="8" Text="Gear cooldown" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="8" Grid.Column="2" Minimum="100" Maximum="700" TickFrequency="50" MinHeight="44" AutomationProperties.Name="Gear shift cooldown" IsSnapToTickEnabled="True" Value="{Binding GearShiftPulseCooldownMs, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="8" Grid.Column="3" Text="{Binding GearShiftPulseCooldownMs, StringFormat={}{0} ms}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="8" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="8" Grid.Column="5" Classes="output muted" Text="Min shift gap" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Tires &amp; Surfaces">
                <ScrollViewer Margin="0,16,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Classes="panel">
                            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="muted" Text="Active tire profile"/>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding WheelTireProfile}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Classes="muted" Text="Tire types"/>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding WheelTireTypes}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Classes="muted" Text="Surface type"/>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding SurfaceType}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="4">
                                    <TextBlock Classes="muted" Text="Raw attribute"/>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding SurfaceAttribute}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4" Spacing="4">
                                    <TextBlock Classes="muted" Text="Active multiplier"/>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding ActiveTireSurfaceMultiplier}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Classes="panel">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel>
                                        <TextBlock Classes="section" Text="Tire x Surface Matrix"/>
                                        <TextBlock Classes="muted" Text="Columns are Tires. Rows are Surface. Enter 1-10; Enter or clicking outside commits the value."/>
                                        <TextBlock Classes="muted" Text="Green is low feedback and red is high feedback."/>
                                        <TextBlock Classes="muted" Text="Multipliers are stored in the selected wheel effects profile."/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Reset matrix defaults"
                                            Command="{Binding ResetMatrixDefaultsCommand}"/>
                                </Grid>

                                <Grid ColumnDefinitions="130,100,100,100,100,100,100,100,110" ColumnSpacing="10">
                                    <TextBlock Classes="muted" Text="Surface rows"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Tire: Street"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Tire: Agric"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Tire: Mud"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Tire: Off-road"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Tire: Tracked"/>
                                    <TextBlock Grid.Column="6" Classes="muted" Text="Tire: Mixed"/>
                                    <TextBlock Grid.Column="7" Classes="muted" Text="Tire: Unknown"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding TireSurfaceMatrixRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="130,100,100,100,100,100,100,100,110" ColumnSpacing="10" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding SurfaceType}" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Classes="tireSurfaceScale" Tag="street" Text="{Binding Street, Mode=OneWay}" Background="{Binding StreetBrush}" TextAlignment="Center" MinHeight="32" KeyDown="OnTireSurfaceScaleKeyDown" TextInput="OnTireSurfaceScaleTextInput" LostFocus="OnTireSurfaceScaleLostFocus"/>
                                                <TextBox Grid.Column="2" Classes="tireSurfaceScale" Tag="agricultural" Text="{Binding Agricultural, Mode=OneWay}" Background="{Binding AgriculturalBrush}" TextAlignment="Center" MinHeight="32" KeyDown="OnTireSurfaceScaleKeyDown" TextInput="OnTireSurfaceScaleTextInput" LostFocus="OnTireSurfaceScaleLostFocus"/>
                                                <TextBox Grid.Column="3" Classes="tireSurfaceScale" Tag="mud" Text="{Binding Mud, Mode=OneWay}" Background="{Binding MudBrush}" TextAlignment="Center" MinHeight="32" KeyDown="OnTireSurfaceScaleKeyDown" TextInput="OnTireSurfaceScaleTextInput" LostFocus="OnTireSurfaceScaleLostFocus"/>
                                                <TextBox Grid.Column="4" Classes="tireSurfaceScale" Tag="offRoad" Text="{Binding OffRoad, Mode=OneWay}" Background="{Binding OffRoadBrush}" TextAlignment="Center" MinHeight="32" KeyDown="OnTireSurfaceScaleKeyDown" TextInput="OnTireSurfaceScaleTextInput" LostFocus="OnTireSurfaceScaleLostFocus"/>
                                                <TextBox Grid.Column="5" Classes="tireSurfaceScale" Tag="tracked" Text="{Binding Tracked, Mode=OneWay}" Background="{Binding TrackedBrush}" TextAlignment="Center" MinHeight="32" KeyDown="OnTireSurfaceScaleKeyDown" TextInput="OnTireSurfaceScaleTextInput" LostFocus="OnTireSurfaceScaleLostFocus"/>
                                                <TextBox Grid.Column="6" Classes="tireSurfaceScale" Tag="mixed" Text="{Binding Mixed, Mode=OneWay}" Background="{Binding MixedBrush}" TextAlignment="Center" MinHeight="32" KeyDown="OnTireSurfaceScaleKeyDown" TextInput="OnTireSurfaceScaleTextInput" LostFocus="OnTireSurfaceScaleLostFocus"/>
                                                <TextBox Grid.Column="7" Classes="tireSurfaceScale" Tag="unknown" Text="{Binding Unknown, Mode=OneWay}" Background="{Binding UnknownBrush}" TextAlignment="Center" MinHeight="32" KeyDown="OnTireSurfaceScaleKeyDown" TextInput="OnTireSurfaceScaleTextInput" LostFocus="OnTireSurfaceScaleLostFocus"/>
                                                <Button Grid.Column="8"
                                                        Content="Reset row"
                                                        Command="{Binding DataContext.ResetSelectedSurfaceCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Classes="panel">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="section" Text="Surface aliases"/>
                                <Grid ColumnDefinitions="*,180,Auto" ColumnSpacing="10">
                                    <TextBox Watermark="Raw surface value" Text="{Binding NewSurfaceAliasRaw, Mode=TwoWay}"/>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding TireSurfaceTargets}" SelectedItem="{Binding SelectedSurfaceAliasTarget, Mode=TwoWay}"/>
                                    <Button Grid.Column="2" Content="Save alias" Command="{Binding SaveAliasCommand}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding SurfaceAliasRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,180" ColumnSpacing="10" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Raw}" VerticalAlignment="Center"/>
                                                <ComboBox Grid.Column="1" ItemsSource="{Binding Targets}" SelectedItem="{Binding Normalized, Mode=TwoWay}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Logs">
                <Border Classes="panel" Margin="0,16,0,0">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,12">
                            <TextBlock Classes="section" Text="Event Log"/>
                            <TextBlock Classes="muted" Text="{Binding LogPath}"/>
                        </StackPanel>
                        <ListBox Classes="logList"
                                 ItemsSource="{Binding LogEvents}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource LogRowBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <Expander>
                                            <Expander.Header>
                                                <Grid ColumnDefinitions="72,104,*,52" ColumnSpacing="12" MinHeight="48" Margin="10,0">
                                                    <TextBlock Classes="logMuted" Text="{Binding Time}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Classes="logMuted" Text="{Binding Level}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Classes="logLine" Text="{Binding Summary}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Classes="logMuted" Text="{Binding CountText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Expander.Header>
                                            <Border Background="{StaticResource LogBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,10,20,14">
                                                <TextBlock Classes="logLine" Text="{Binding Details}" TextWrapping="Wrap"/>
                                            </Border>
                                        </Expander>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
