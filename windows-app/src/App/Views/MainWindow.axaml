<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FS25FfbBridge.App.ViewModels"
        x:Class="FS25FfbBridge.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Icon="/Assets/avalonia-logo.ico"
        Title="FS25 FFB Bridge"
        Background="#F3F1EC">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F1EC"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FAF9F5"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#F0EEE8"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D8D4CA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#111612"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#5E665F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0D6F63"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#DDEBE6"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#D9E7DF"/>
        <SolidColorBrush x:Key="SelectionStrongBrush" Color="#1E6A59"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#8D1D22"/>
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#F4DADC"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#8A5A00"/>
        <SolidColorBrush x:Key="WarningSoftBrush" Color="#F3E7C2"/>
        <SolidColorBrush x:Key="DisabledTextBrush" Color="#8D928C"/>
        <SolidColorBrush x:Key="DisabledSurfaceBrush" Color="#ECE9E2"/>
        <SolidColorBrush x:Key="CodeBackgroundBrush" Color="#EEECE6"/>
        <SolidColorBrush x:Key="LogBackgroundBrush" Color="#20201E"/>
        <SolidColorBrush x:Key="LogTextBrush" Color="#E8E1D4"/>
        <SolidColorBrush x:Key="LogMutedBrush" Color="#AFA894"/>
    </Window.Resources>
    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TextBlock.section">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="0,10,0,8"/>
            <Setter Property="Margin" Value="0,0,26,0"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TabItem TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        </Style>
        <Style Selector="TabItem:selected TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Border.badge">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,7"/>
        </Style>
        <Style Selector="Border.badge.good">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
        <Style Selector="Border.badge.warn">
            <Setter Property="Background" Value="{StaticResource WarningSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
        </Style>
        <Style Selector="Border.badge.bad">
            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
        </Style>
        <Style Selector="Border.badge TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="#FFF9F1"/>
        </Style>
        <Style Selector="Button.test">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FFF9F1"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Background" Value="{StaticResource DisabledSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="TextBox.mono">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{StaticResource CodeBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>
        <Style Selector="ListBox.logList">
            <Setter Property="Background" Value="{StaticResource LogBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LogBackgroundBrush}"/>
        </Style>
        <Style Selector="ListBox.logList ListBoxItem:selected">
            <Setter Property="Background" Value="#3A3934"/>
            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}"/>
        </Style>
        <Style Selector="ListBox.logList ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}"/>
        </Style>
        <Style Selector="TextBlock.logLine">
            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="TextBlock.output">
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="TextBlock.unavailable">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="18,14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <StackPanel Spacing="2">
                    <TextBlock Classes="title" Text="FS25 FFB Bridge"/>
                    <TextBlock Text="DirectInput gameplay effects plus FS25 telemetry"
                               Foreground="#1D211F"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="1" VerticalAlignment="Center">
                    <Border Classes="badge"
                            Classes.good="{Binding IsTelemetryConnected}"
                            Classes.warn="{Binding IsTelemetryWaiting}"
                            Classes.bad="{Binding IsTelemetryLost}">
                        <TextBlock Text="{Binding TelemetryReadyText}"/>
                    </Border>
                    <Border Classes="badge"
                            Classes.good="{Binding IsFfbOperational}"
                            Classes.warn="{Binding IsFfbBlocked}">
                        <TextBlock Text="{Binding FfbReadyText}"/>
                    </Border>
                    <Border Classes="badge"
                            Classes.good="{Binding IsFfbReady}"
                            Classes.warn="{Binding IsFfbInactive}">
                        <TextBlock Text="{Binding WheelReadyText}"/>
                    </Border>
                    <Button Classes="danger"
                            Content="Emergency Stop"
                            MinHeight="44"
                            AutomationProperties.Name="Emergency stop all force feedback"
                            Command="{Binding StopAllEffectsCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="18">
            <TabItem Header="Dashboard">
                <ScrollViewer Margin="0,16,0,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
                        <UniformGrid Columns="3" Rows="1">
                            <Border Classes="panel" Margin="0,0,10,0" MinHeight="170">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="section" Text="Wheel"/>
                                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding WheelStatus}" TextWrapping="Wrap"/>
                                    <TextBlock Classes="muted" Text="{Binding WheelReason}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding WheelNextAction}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="panel" Margin="0,0,10,0" MinHeight="170">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="section" Text="FS25 Telemetry"/>
                                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding TelemetryStatusText}" TextWrapping="Wrap"/>
                                    <TextBlock Classes="muted" Text="{Binding TelemetryReason}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding TelemetryNextAction}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="panel" MinHeight="170">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="section" Text="Force Feedback"/>
                                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding FfbStatus}" TextWrapping="Wrap"/>
                                    <TextBlock Classes="muted" Text="{Binding FfbReason}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding FfbNextAction}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="1" Classes="panel">
                            <StackPanel Spacing="14">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel>
                                        <TextBlock Classes="section" Text="Global Force Limit"/>
                                        <TextBlock Classes="muted" Text="One safety cap for every test, effect, wheel, and vehicle profile."/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Classes="danger"
                                            Content="Emergency Stop"
                                            MinHeight="44"
                                            AutomationProperties.Name="Emergency stop all force feedback"
                                            Command="{Binding StopAllEffectsCommand}"/>
                                </Grid>
                                <Grid ColumnDefinitions="150,*,52" RowDefinitions="44" RowSpacing="8" ColumnSpacing="10">
                                    <TextBlock Text="Force limit" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5"
                                            MinHeight="44"
                                            AutomationProperties.Name="Global force limit for all force feedback"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding GlobalForceLimitPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding GlobalForceLimitPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Expander Grid.Row="2" Header="Diagnostics">
                            <Border Classes="panel">
                                <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                    <TextBlock Classes="muted" Text="Backend"/>
                                    <TextBlock Grid.Column="1" Text="{Binding BackendStatus}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="1" Classes="muted" Text="Panic hotkey"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PanicHotkey}"/>
                                    <TextBlock Grid.Row="2" Classes="muted" Text="Active effects"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Classes="output" Text="{Binding ActiveGameplayEffects}"/>
                                    <TextBlock Grid.Row="3" Classes="muted" Text="Active category"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ActiveVehicleCategory}"/>
                                    <TextBlock Grid.Row="4" Classes="muted" Text="Outputs"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Classes="output">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}Spring {0}, damper {1}, friction {2}, vibration {3}, surface {4}, slip {5}, bump {6}">
                                                <Binding Path="SpringOutput"/>
                                                <Binding Path="DamperOutput"/>
                                                <Binding Path="FrictionOutput"/>
                                                <Binding Path="EngineVibrationOutput"/>
                                                <Binding Path="SurfaceFeedbackOutput"/>
                                                <Binding Path="SlipFeedbackOutput"/>
                                                <Binding Path="BumpFeedbackOutput"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Grid.Row="5" Classes="muted" Text="Telemetry fade"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding TelemetryFade}"/>
                                    <TextBlock Grid.Row="6" Classes="muted" Text="Config path"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Classes="output" Text="{Binding ConfigPath}"/>
                                    <TextBlock Grid.Row="7" Classes="muted" Text="Log path"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Classes="output" Text="{Binding LogPath}"/>
                                </Grid>
                            </Border>
                        </Expander>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Device">
                <Grid ColumnDefinitions="360,*" ColumnSpacing="16" Margin="0,16,0,0">
                    <Border Classes="panel">
                        <DockPanel LastChildFill="True">
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Classes="section" Text="DirectInput Devices"/>
                                    <TextBlock Classes="muted" Text="{Binding DeviceCountText}"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Scan"
                                        MinHeight="44"
                                        AutomationProperties.Name="Scan DirectInput devices"
                                        Command="{Binding ScanDevicesCommand}"/>
                            </Grid>
                            <ListBox ItemsSource="{Binding Devices}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectedItem="{Binding SelectedDevice, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="3" Margin="0,6">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding FfbStatus}" Classes="muted"/>
                                            <TextBlock Text="{Binding DeviceType}" Classes="muted"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="16">
                        <Border Classes="panel">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="section" Text="Selected Device"/>
                                <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                    <TextBlock Classes="muted" Text="Name"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedDevice.DisplayName, FallbackValue=None}"/>
                                    <TextBlock Grid.Row="1" Classes="muted" Text="Status"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDeviceStatus}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="2" Classes="muted" Text="FFB support"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DeviceCapabilityStatus}" TextWrapping="Wrap"/>
                                </Grid>
                                <Expander Header="More device details">
                                    <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" Margin="0,8,0,0">
                                        <TextBlock Classes="muted" Text="Stable ID"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedDevice.StableId, FallbackValue=None}" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="1" Classes="muted" Text="Instance GUID"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDevice.InstanceGuid, FallbackValue=None}" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="2" Classes="muted" Text="Axes / effects"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}; {1}">
                                                    <Binding Path="SelectedDevice.AxesText" FallbackValue="None"/>
                                                    <Binding Path="SelectedDevice.EffectsText" FallbackValue="None"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Classes="panel">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="section" Text="Test Effects"/>
                                <UniformGrid Columns="3" Rows="2">
                                    <Button Classes="test" Margin="0,0,8,8" MinHeight="44" Content="Spring" AutomationProperties.Name="Run spring test" Command="{Binding SpringTestCommand}"/>
                                    <Button Classes="test" Margin="0,0,8,8" MinHeight="44" Content="Damper" AutomationProperties.Name="Run damper test" Command="{Binding DamperTestCommand}"/>
                                    <Button Classes="test" Margin="0,0,0,8" MinHeight="44" Content="Vibration" AutomationProperties.Name="Run vibration test" Command="{Binding LowVibrationCommand}"/>
                                    <Button Margin="0,0,8,0" MinHeight="44" Content="Left" AutomationProperties.Name="Run constant left test" Command="{Binding ConstantLeftCommand}"/>
                                    <Button Margin="0,0,8,0" MinHeight="44" Content="Right" AutomationProperties.Name="Run constant right test" Command="{Binding ConstantRightCommand}"/>
                                    <Button Classes="danger" MinHeight="44" Content="Stop All" AutomationProperties.Name="Stop all force feedback effects" Command="{Binding StopAllEffectsCommand}"/>
                                </UniformGrid>
                                <TextBlock Classes="muted"
                                           Text="Use low limits first on old wheels. Stop All is safe to press repeatedly."/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Telemetry">
                <Grid ColumnDefinitions="1.05*,1*" RowDefinitions="Auto,*" ColumnSpacing="16" RowSpacing="16" Margin="0,16,0,0">
                    <Border Classes="panel">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="section" Text="Connection"/>
                            <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Classes="muted" Text="Status"/>
                                <TextBlock Grid.Column="1" Text="{Binding TelemetryStatus}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Classes="muted" Text="Endpoint"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TelemetryEndpoint}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Classes="muted" Text="UDP"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UdpStatus}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" Classes="muted" Text="File fallback"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FileStatus}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="4" Classes="muted" Text="Last source"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastPacketSource}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="5" Classes="muted" Text="Packet rate"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding PacketRate}"/>
                                <TextBlock Grid.Row="6" Classes="muted" Text="Last packet age"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding LastPacketAge}"/>
                                <TextBlock Grid.Row="7" Classes="muted" Text="Parser"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding TelemetryParseStatus}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="8" Classes="muted" Text="Transport error"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding LastTransportError}" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="panel">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="section" Text="Vehicle"/>
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Classes="muted" Text="Vehicle"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentVehicle}"/>
                                <TextBlock Grid.Row="1" Classes="muted" Text="Type"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VehicleType}"/>
                                <TextBlock Grid.Row="2" Classes="muted" Text="Category"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding VehicleCategory}"/>
                                <TextBlock Grid.Row="3" Classes="muted" Text="Game state"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GameState}"/>
                                <TextBlock Grid.Row="4" Classes="muted" Text="Speed"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SpeedKmh}"/>
                                <TextBlock Grid.Row="5" Classes="muted" Text="Steering"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SteeringAngle}"/>
                                <TextBlock Grid.Row="6" Classes="muted" Text="RPM"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Rpm}"/>
                                <TextBlock Grid.Row="7" Classes="muted" Text="Engine"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding EngineStatus}"/>
                                <TextBlock Grid.Row="8" Classes="muted" Text="Mass / total"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding MassAndTotal}"/>
                                <TextBlock Grid.Row="9" Classes="muted" Text="On field"/>
                                <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding IsOnField}"/>
                                <TextBlock Grid.Row="10" Classes="muted" Text="Surface"/>
                                <TextBlock Grid.Row="10" Grid.Column="1">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} / attr {1}">
                                            <Binding Path="SurfaceType"/>
                                            <Binding Path="SurfaceAttribute"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Grid.Row="11" Classes="muted" Text="Wetness / rain"/>
                                <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding WetnessAndRain}"/>
                                <TextBlock Grid.Row="12" Classes="muted" Text="Slip avg / max"/>
                                <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding WheelSlip}"/>
                                <TextBlock Grid.Row="13" Classes="muted" Text="Ground contact"/>
                                <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding GroundContactRatio}"/>
                                <TextBlock Grid.Row="14" Classes="muted" Text="Pitch / roll / slope"/>
                                <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding Attitude}"/>
                                <TextBlock Grid.Row="15" Classes="muted" Text="Local accel"/>
                                <TextBlock Grid.Row="15" Grid.Column="1" Text="{Binding LocalAcceleration}"/>
                                <TextBlock Grid.Row="16" Classes="muted" Text="Bump impulse"/>
                                <TextBlock Grid.Row="16" Grid.Column="1" Text="{Binding BumpImpulse}"/>
                                <TextBlock Grid.Row="17" Classes="muted" Text="Tire types"/>
                                <TextBlock Grid.Row="17" Grid.Column="1" Text="{Binding WheelTireTypes}"/>
                                <TextBlock Grid.Row="18" Classes="muted" Text="Tire profile"/>
                                <TextBlock Grid.Row="18" Grid.Column="1" Text="{Binding WheelTireProfile}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Expander Grid.Row="1" Grid.ColumnSpan="2" Header="Diagnostics">
                        <Border Classes="panel">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Classes="section" Text="Raw Packet" Margin="0,0,0,10"/>
                                <TextBox Classes="mono"
                                         Text="{Binding RawTelemetryPreview}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         MinHeight="180"/>
                            </DockPanel>
                        </Border>
                    </Expander>
                </Grid>
            </TabItem>

            <TabItem Header="Effects">
                <ScrollViewer Margin="0,16,0,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Border Classes="panel">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Classes="section" Text="Gameplay Effects"/>
                                <TextBlock Classes="muted" Text="Conservative Logitech MOMO defaults. Stop All pauses runtime output without changing this profile setting."/>
                                <TextBlock Classes="muted">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}Runtime {0} / category {1}">
                                            <Binding Path="GameplayFfbRuntimeStatus"/>
                                            <Binding Path="ActiveVehicleCategory"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      VerticalAlignment="Center"
                                      MinHeight="44"
                                      AutomationProperties.Name="Enable gameplay force feedback"
                                      Content="FFB Enabled"
                                      IsChecked="{Binding GameplayFfbEnabled, Mode=TwoWay}"/>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <Button Content="&lt;"
                                    MinWidth="36"
                                    Padding="0,7"
                                    Command="{Binding PreviousEffectCategoryCommand}"/>
                            <ScrollViewer x:Name="EffectCategoryScroller"
                                          Grid.Column="1"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled">
                                <TabControl x:Name="EffectCategoryTabs"
                                            ItemsSource="{Binding EffectCategoryOptions}"
                                            SelectedItem="{Binding SelectedEffectCategoryOption, Mode=TwoWay}"
                                            SelectionChanged="OnEffectCategorySelectionChanged"
                                            Height="48">
                                    <TabControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </TabControl.ItemTemplate>
                                </TabControl>
                            </ScrollViewer>
                            <Button Grid.Column="2"
                                    Content="&gt;"
                                    MinWidth="36"
                                    Padding="0,7"
                                    Command="{Binding NextEffectCategoryCommand}"/>
                        </Grid>

                        <Grid ColumnDefinitions="180,*,48" ColumnSpacing="10">
                            <TextBlock Text="Global Force Limit" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5"
                                    MinHeight="44"
                                    AutomationProperties.Name="Global force limit for all profiles"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding GlobalForceLimitPercent, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding GlobalForceLimitPercent, StringFormat={}{0}%}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Spacing="18">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Steering Load"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="Steering spring" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable steering spring" IsChecked="{Binding SpeedSpringEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Steering spring strength" IsSnapToTickEnabled="True" Value="{Binding SpeedSpringStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SpeedSpringStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding SpeedSpringCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding SpringOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Mechanical friction" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="2" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable mechanical friction" IsChecked="{Binding MechanicalFrictionEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="2" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Mechanical friction strength" IsSnapToTickEnabled="True" Value="{Binding MechanicalFrictionStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding MechanicalFrictionStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding MechanicalFrictionCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output" Text="{Binding FrictionOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Contact relief controls" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output muted" Text="Hidden modifier only" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Speed Stability"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="Road damping" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable road damping" IsChecked="{Binding SpeedDamperEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Road damping strength" IsSnapToTickEnabled="True" Value="{Binding SpeedDamperStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SpeedDamperStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding SpeedDamperCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding DamperOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Anti-oscillation" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output muted" Text="Not tunable" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Slew smoothing" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output muted" Text="Not implemented" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Surface &amp; Traction"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="Surface feedback" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable surface feedback" IsChecked="{Binding SurfaceFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Surface feedback strength" IsSnapToTickEnabled="True" Value="{Binding SurfaceFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SurfaceFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding SurfaceFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding SurfaceFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Slip feedback" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="2" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable slip feedback" IsChecked="{Binding SlipFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="2" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Slip feedback strength" IsSnapToTickEnabled="True" Value="{Binding SlipFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding SlipFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding SlipFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output" Text="{Binding SlipFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Wetness" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="3" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable wetness feedback" IsChecked="{Binding WetnessFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="3" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Wetness feedback strength" IsSnapToTickEnabled="True" Value="{Binding WetnessFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding WetnessFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="3" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding WetnessFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output" Text="{Binding WetnessFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Text="Steering slip relief" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="5" Classes="output muted" Text="Hidden modifier only" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Suspension &amp; Terrain"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="Bump" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable bump feedback" IsChecked="{Binding BumpFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Bump feedback strength" IsSnapToTickEnabled="True" Value="{Binding BumpFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding BumpFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding BumpFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding BumpFeedbackOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Left suspension hit" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output muted" Text="No DI channel yet" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Right suspension hit" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output muted" Text="No DI channel yet" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Text="Landing pulse" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="5" Classes="output muted" Text="Not implemented" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="5" Text="Terrain rumble" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="5" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="5" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="5" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="5" Grid.Column="5" Classes="output muted" Text="No DI channel yet" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Load, Slope &amp; Implement"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="Load resistance" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable load resistance" IsChecked="{Binding LoadResistanceEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Load resistance strength" IsSnapToTickEnabled="True" Value="{Binding LoadResistanceStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding LoadResistanceStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding LoadResistanceCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding LoadFactor}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Motion" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="2" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable motion feedback" IsChecked="{Binding MotionFeedbackEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="2" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="Motion feedback strength" IsSnapToTickEnabled="True" Value="{Binding MotionFeedbackStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding MotionFeedbackStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding MotionFeedbackCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output" Text="{Binding DamperOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Hill standstill load" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output muted" Text="Not implemented" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Text="Side slope bias" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="5" Classes="output muted" Text="Not implemented" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="5" Text="Implement bias" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="5" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="5" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="5" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="5" Grid.Column="5" Classes="output muted" Text="Not implemented" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="Engine &amp; Drivetrain"/>
                                <Grid ColumnDefinitions="132,86,*,50,112,130"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                      RowSpacing="10"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="muted" Text="Effect"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                                    <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                                    <TextBlock Grid.Column="3" Classes="muted" Text="Value"/>
                                    <TextBlock Grid.Column="4" Classes="muted" Text="Curve"/>
                                    <TextBlock Grid.Column="5" Classes="muted" Text="Live output"/>

                                    <TextBlock Grid.Row="1" Text="RPM vibration" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" MinHeight="44" AutomationProperties.Name="Enable RPM vibration" IsChecked="{Binding EngineVibrationEnabled, Mode=TwoWay}"/>
                                    <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5" MinHeight="44" AutomationProperties.Name="RPM vibration strength" IsSnapToTickEnabled="True" Value="{Binding EngineVibrationStrengthPercent, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding EngineVibrationStrengthPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" MinHeight="44" ItemsSource="{Binding CurveKinds}" SelectedItem="{Binding EngineVibrationCurve, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Classes="output" Text="{Binding EngineVibrationOutput}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Gear shift pulse" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Classes="output muted" Text="Not implemented" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Clutch/brake jerk" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="5" Classes="output muted" Text="Not implemented" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Text="Engine start/stop" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Classes="unavailable" Text="X" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Classes="muted" Text="Planned" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="3" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="4" Classes="muted" Text="-" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Grid.Column="5" Classes="output muted" Text="Not implemented" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Logs">
                <Border Classes="panel" Margin="0,16,0,0">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,12">
                            <TextBlock Classes="section" Text="Event Log"/>
                            <TextBlock Classes="muted" Text="{Binding LogPath}"/>
                        </StackPanel>
                        <ListBox Classes="logList"
                                 ItemsSource="{Binding LogEvents}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Expander>
                                        <Expander.Header>
                                            <Grid ColumnDefinitions="64,92,*,52" ColumnSpacing="10" MinHeight="44">
                                                <TextBlock Classes="logLine" Text="{Binding Time}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Classes="logLine" Text="{Binding Level}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Classes="logLine" Text="{Binding Summary}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Classes="logLine" Text="{Binding CountText}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Expander.Header>
                                        <TextBlock Classes="logLine" Text="{Binding Details}" TextWrapping="Wrap" Margin="74,6,0,10"/>
                                    </Expander>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
