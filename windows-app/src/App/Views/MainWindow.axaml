<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FS25FfbBridge.App.ViewModels"
        x:Class="FS25FfbBridge.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Icon="/Assets/avalonia-logo.ico"
        Title="FS25 FFB Bridge"
        Background="#F3F1EC">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F1EC"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FAF9F5"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#F0EEE8"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D8D4CA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#111612"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#5E665F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0D6F63"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#DDEBE6"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#D9E7DF"/>
        <SolidColorBrush x:Key="SelectionStrongBrush" Color="#1E6A59"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#8D1D22"/>
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#F4DADC"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#8A5A00"/>
        <SolidColorBrush x:Key="WarningSoftBrush" Color="#F3E7C2"/>
        <SolidColorBrush x:Key="DisabledTextBrush" Color="#8D928C"/>
        <SolidColorBrush x:Key="DisabledSurfaceBrush" Color="#ECE9E2"/>
        <SolidColorBrush x:Key="CodeBackgroundBrush" Color="#EEECE6"/>
        <SolidColorBrush x:Key="LogBackgroundBrush" Color="#20201E"/>
        <SolidColorBrush x:Key="LogTextBrush" Color="#E8E1D4"/>
        <SolidColorBrush x:Key="LogMutedBrush" Color="#AFA894"/>
    </Window.Resources>
    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TextBlock.section">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="0,10,0,8"/>
            <Setter Property="Margin" Value="0,0,26,0"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TabItem TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        </Style>
        <Style Selector="TabItem:selected TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Border.badge">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,7"/>
        </Style>
        <Style Selector="Border.badge.good">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
        <Style Selector="Border.badge.warn">
            <Setter Property="Background" Value="{StaticResource WarningSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
        </Style>
        <Style Selector="Border.badge.bad">
            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
        </Style>
        <Style Selector="Border.badge TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="#FFF9F1"/>
        </Style>
        <Style Selector="Button.test">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FFF9F1"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Background" Value="{StaticResource DisabledSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style Selector="TextBox.mono">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{StaticResource CodeBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>
        <Style Selector="ListBox.logList">
            <Setter Property="Background" Value="{StaticResource LogBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LogBackgroundBrush}"/>
        </Style>
        <Style Selector="ListBox.logList ListBoxItem:selected">
            <Setter Property="Background" Value="#3A3934"/>
            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}"/>
        </Style>
        <Style Selector="ListBox.logList ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}"/>
        </Style>
        <Style Selector="TextBlock.logLine">
            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="TextBlock.output">
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="18,14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <StackPanel Spacing="2">
                    <TextBlock Classes="title" Text="FS25 FFB Bridge"/>
                    <TextBlock Text="DirectInput gameplay effects plus FS25 telemetry"
                               Foreground="#1D211F"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="1" VerticalAlignment="Center">
                    <Border Classes="badge"
                            Classes.good="{Binding IsTelemetryConnected}"
                            Classes.warn="{Binding IsTelemetryWaiting}"
                            Classes.bad="{Binding IsTelemetryLost}">
                        <TextBlock Text="{Binding TelemetryReadyText}"/>
                    </Border>
                    <Border Classes="badge"
                            Classes.good="{Binding IsFfbReady}"
                            Classes.warn="{Binding IsFfbInactive}">
                        <TextBlock Text="{Binding FfbReadyText}"/>
                    </Border>
                    <Button Classes="danger"
                            Content="Emergency Stop"
                            Command="{Binding StopAllEffectsCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="18">
            <TabItem Header="Dashboard">
                <Grid ColumnDefinitions="1.2*,1*" RowDefinitions="Auto,*" ColumnSpacing="16" RowSpacing="16" Margin="0,16,0,0">
                    <Border Classes="panel">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="section" Text="Current State"/>
                            <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Classes="muted" Text="Selected wheel"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedDevice.DisplayName, FallbackValue=None}"/>
                                <TextBlock Grid.Row="1" Classes="muted" Text="Device status"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDeviceStatus}"/>
                                <TextBlock Grid.Row="2" Classes="muted" Text="FFB capability"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DeviceCapabilityStatus}"/>
                                <TextBlock Grid.Row="3" Classes="muted" Text="Backend"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding BackendStatus}"/>
                                <TextBlock Grid.Row="4" Classes="muted" Text="Panic hotkey"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PanicHotkey}"/>
                                <TextBlock Grid.Row="5" Classes="muted" Text="Gameplay FFB"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding GameplayFfbEnabled}"/>
                                <TextBlock Grid.Row="6" Classes="muted" Text="FFB runtime"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding GameplayFfbRuntimeStatus}"/>
                                <TextBlock Grid.Row="7" Classes="muted" Text="Active effects"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Classes="output" Text="{Binding ActiveGameplayEffects}"/>
                                <TextBlock Grid.Row="8" Classes="muted" Text="Active category"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding ActiveVehicleCategory}"/>
                                <TextBlock Grid.Row="9" Classes="muted" Text="Spring / damper / friction"/>
                                <TextBlock Grid.Row="9" Grid.Column="1">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} / {1} / {2}">
                                            <Binding Path="SpringOutput"/>
                                            <Binding Path="DamperOutput"/>
                                            <Binding Path="FrictionOutput"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Grid.Row="10" Classes="muted" Text="Vibration"/>
                                <TextBlock Grid.Row="10" Grid.Column="1" Classes="output">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}RPM {0}, Surface {1}, Slip {2}, Bump {3}">
                                            <Binding Path="EngineVibrationOutput"/>
                                            <Binding Path="SurfaceFeedbackOutput"/>
                                            <Binding Path="SlipFeedbackOutput"/>
                                            <Binding Path="BumpFeedbackOutput"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Grid.Row="11" Classes="muted" Text="Load factor"/>
                                <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding LoadFactor}"/>
                                <TextBlock Grid.Row="12" Classes="muted" Text="Telemetry fade"/>
                                <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding TelemetryFade}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="panel">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section" Text="Safety Limits"/>
                            <TextBlock Classes="muted" Text="All test effects are capped by both limits."/>
                            <Grid ColumnDefinitions="150,*,48" RowDefinitions="Auto,Auto" RowSpacing="12" ColumnSpacing="10">
                                <TextBlock Text="Global limit" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding GlobalForceLimitPercent, Mode=TwoWay}"/>
                                <TextBlock Grid.Column="2" Text="{Binding GlobalForceLimitPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Text="Device limit" VerticalAlignment="Center"/>
                                <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding DeviceForceLimitPercent, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding DeviceForceLimitPercent, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.ColumnSpan="2" Classes="panel">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="section" Text="Paths"/>
                            <TextBlock Classes="output" Text="{Binding ConfigPath}"/>
                            <TextBlock Classes="output" Text="{Binding LogPath}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Device">
                <Grid ColumnDefinitions="360,*" ColumnSpacing="16" Margin="0,16,0,0">
                    <Border Classes="panel">
                        <DockPanel LastChildFill="True">
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Classes="section" Text="DirectInput Devices"/>
                                    <TextBlock Classes="muted" Text="{Binding DeviceCountText}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Scan" Command="{Binding ScanDevicesCommand}"/>
                            </Grid>
                            <ListBox ItemsSource="{Binding Devices}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectedItem="{Binding SelectedDevice, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="3" Margin="0,6">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding FfbStatus}" Classes="muted"/>
                                            <TextBlock Text="{Binding DeviceType}" Classes="muted"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="16">
                        <Border Classes="panel">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="section" Text="Selected Device"/>
                                <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                    <TextBlock Classes="muted" Text="Name"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedDevice.DisplayName, FallbackValue=None}"/>
                                    <TextBlock Grid.Row="1" Classes="muted" Text="Stable ID"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDevice.StableId, FallbackValue=None}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="2" Classes="muted" Text="Instance GUID"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedDevice.InstanceGuid, FallbackValue=None}"/>
                                    <TextBlock Grid.Row="3" Classes="muted" Text="Axes"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedDevice.AxesText, FallbackValue=None}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="4" Classes="muted" Text="Effects"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedDevice.EffectsText, FallbackValue=None}" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Classes="panel">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="section" Text="Test Effects"/>
                                <UniformGrid Columns="3" Rows="2">
                                    <Button Classes="test" Margin="0,0,8,8" Content="Spring" Command="{Binding SpringTestCommand}"/>
                                    <Button Classes="test" Margin="0,0,8,8" Content="Damper" Command="{Binding DamperTestCommand}"/>
                                    <Button Classes="test" Margin="0,0,0,8" Content="Vibration" Command="{Binding LowVibrationCommand}"/>
                                    <Button Margin="0,0,8,0" Content="Constant Left" Command="{Binding ConstantLeftCommand}"/>
                                    <Button Margin="0,0,8,0" Content="Constant Right" Command="{Binding ConstantRightCommand}"/>
                                    <Button Classes="danger" Content="Stop All" Command="{Binding StopAllEffectsCommand}"/>
                                </UniformGrid>
                                <TextBlock Classes="muted"
                                           Text="Use low limits first on old wheels. Stop All is safe to press repeatedly."/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Telemetry">
                <Grid ColumnDefinitions="1.05*,1*" RowDefinitions="Auto,*" ColumnSpacing="16" RowSpacing="16" Margin="0,16,0,0">
                    <Border Classes="panel">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="section" Text="Connection"/>
                            <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Classes="muted" Text="Status"/>
                                <TextBlock Grid.Column="1" Text="{Binding TelemetryStatus}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Classes="muted" Text="Endpoint"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TelemetryEndpoint}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Classes="muted" Text="UDP"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UdpStatus}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" Classes="muted" Text="File fallback"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FileStatus}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="4" Classes="muted" Text="Last source"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastPacketSource}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="5" Classes="muted" Text="Packet rate"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding PacketRate}"/>
                                <TextBlock Grid.Row="6" Classes="muted" Text="Last packet age"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding LastPacketAge}"/>
                                <TextBlock Grid.Row="7" Classes="muted" Text="Parser"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding TelemetryParseStatus}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="8" Classes="muted" Text="Transport error"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding LastTransportError}" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="panel">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="section" Text="Vehicle"/>
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Classes="muted" Text="Vehicle"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentVehicle}"/>
                                <TextBlock Grid.Row="1" Classes="muted" Text="Type"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VehicleType}"/>
                                <TextBlock Grid.Row="2" Classes="muted" Text="Category"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding VehicleCategory}"/>
                                <TextBlock Grid.Row="3" Classes="muted" Text="Game state"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GameState}"/>
                                <TextBlock Grid.Row="4" Classes="muted" Text="Speed"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SpeedKmh}"/>
                                <TextBlock Grid.Row="5" Classes="muted" Text="Steering"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SteeringAngle}"/>
                                <TextBlock Grid.Row="6" Classes="muted" Text="RPM"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Rpm}"/>
                                <TextBlock Grid.Row="7" Classes="muted" Text="Engine"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding EngineStatus}"/>
                                <TextBlock Grid.Row="8" Classes="muted" Text="Mass / total"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding MassAndTotal}"/>
                                <TextBlock Grid.Row="9" Classes="muted" Text="On field"/>
                                <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding IsOnField}"/>
                                <TextBlock Grid.Row="10" Classes="muted" Text="Surface"/>
                                <TextBlock Grid.Row="10" Grid.Column="1">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} / attr {1}">
                                            <Binding Path="SurfaceType"/>
                                            <Binding Path="SurfaceAttribute"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Grid.Row="11" Classes="muted" Text="Wetness / rain"/>
                                <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding WetnessAndRain}"/>
                                <TextBlock Grid.Row="12" Classes="muted" Text="Slip avg / max"/>
                                <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding WheelSlip}"/>
                                <TextBlock Grid.Row="13" Classes="muted" Text="Ground contact"/>
                                <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding GroundContactRatio}"/>
                                <TextBlock Grid.Row="14" Classes="muted" Text="Pitch / roll / slope"/>
                                <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding Attitude}"/>
                                <TextBlock Grid.Row="15" Classes="muted" Text="Local accel"/>
                                <TextBlock Grid.Row="15" Grid.Column="1" Text="{Binding LocalAcceleration}"/>
                                <TextBlock Grid.Row="16" Classes="muted" Text="Bump impulse"/>
                                <TextBlock Grid.Row="16" Grid.Column="1" Text="{Binding BumpImpulse}"/>
                                <TextBlock Grid.Row="17" Classes="muted" Text="Tire types"/>
                                <TextBlock Grid.Row="17" Grid.Column="1" Text="{Binding WheelTireTypes}"/>
                                <TextBlock Grid.Row="18" Classes="muted" Text="Tire profile"/>
                                <TextBlock Grid.Row="18" Grid.Column="1" Text="{Binding WheelTireProfile}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.ColumnSpan="2" Classes="panel">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Classes="section" Text="Raw Packet" Margin="0,0,0,10"/>
                            <TextBox Classes="mono"
                                     Text="{Binding RawTelemetryPreview}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     MinHeight="180"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Effects">
                <ScrollViewer Margin="0,16,0,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Border Classes="panel">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Classes="section" Text="Gameplay Effects"/>
                                <TextBlock Classes="muted" Text="Conservative Logitech MOMO defaults. Stop All pauses runtime output without changing this profile setting."/>
                                <TextBlock Classes="muted">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}Runtime {0} / category {1}">
                                            <Binding Path="GameplayFfbRuntimeStatus"/>
                                            <Binding Path="ActiveVehicleCategory"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Content="FFB Enabled"
                                      IsChecked="{Binding GameplayFfbEnabled, Mode=TwoWay}"/>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <Button Content="&lt;"
                                    MinWidth="36"
                                    Padding="0,7"
                                    Command="{Binding PreviousEffectCategoryCommand}"/>
                            <ScrollViewer x:Name="EffectCategoryScroller"
                                          Grid.Column="1"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled">
                                <TabControl x:Name="EffectCategoryTabs"
                                            ItemsSource="{Binding EffectCategories}"
                                            SelectedItem="{Binding SelectedEffectCategory, Mode=TwoWay}"
                                            SelectionChanged="OnEffectCategorySelectionChanged"
                                            Height="48"/>
                            </ScrollViewer>
                            <Button Grid.Column="2"
                                    Content="&gt;"
                                    MinWidth="36"
                                    Padding="0,7"
                                    Command="{Binding NextEffectCategoryCommand}"/>
                        </Grid>

                        <Grid ColumnDefinitions="180,*,48" ColumnSpacing="10">
                            <TextBlock Text="Overall FFB Strength" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding GameplayFfbOverallStrengthPercent, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding GameplayFfbOverallStrengthPercent, StringFormat={}{0}%}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="145,72,*,112,130"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="10"
                              ColumnSpacing="12">
                            <TextBlock Classes="muted" Text="Effect"/>
                            <TextBlock Grid.Column="1" Classes="muted" Text="Enabled"/>
                            <TextBlock Grid.Column="2" Classes="muted" Text="Strength"/>
                            <TextBlock Grid.Column="3" Classes="muted" Text="Curve"/>
                            <TextBlock Grid.Column="4" Classes="muted" Text="Live output"/>

                            <TextBlock Grid.Row="1" Text="Speed Spring" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding SpeedSpringEnabled, Mode=TwoWay}"/>
                            <Slider Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding SpeedSpringStrengthPercent, Mode=TwoWay}"/>
                            <ComboBox Grid.Row="1" Grid.Column="3"
                                      ItemsSource="{Binding CurveKinds}"
                                      SelectedItem="{Binding SpeedSpringCurve, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="1" Grid.Column="4" Classes="output" Text="{Binding SpringOutput}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Text="Speed Damper" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding SpeedDamperEnabled, Mode=TwoWay}"/>
                            <Slider Grid.Row="2" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding SpeedDamperStrengthPercent, Mode=TwoWay}"/>
                            <ComboBox Grid.Row="2" Grid.Column="3"
                                      ItemsSource="{Binding CurveKinds}"
                                      SelectedItem="{Binding SpeedDamperCurve, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="2" Grid.Column="4" Classes="output" Text="{Binding DamperOutput}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="3" Text="Mechanical Friction" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding MechanicalFrictionEnabled, Mode=TwoWay}"/>
                            <Slider Grid.Row="3" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding MechanicalFrictionStrengthPercent, Mode=TwoWay}"/>
                            <ComboBox Grid.Row="3" Grid.Column="3"
                                      ItemsSource="{Binding CurveKinds}"
                                      SelectedItem="{Binding MechanicalFrictionCurve, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="3" Grid.Column="4" Classes="output" Text="{Binding FrictionOutput}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="4" Text="Load Resistance" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding LoadResistanceEnabled, Mode=TwoWay}"/>
                            <Slider Grid.Row="4" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding LoadResistanceStrengthPercent, Mode=TwoWay}"/>
                            <ComboBox Grid.Row="4" Grid.Column="3"
                                      ItemsSource="{Binding CurveKinds}"
                                      SelectedItem="{Binding LoadResistanceCurve, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="4" Grid.Column="4" Classes="output" Text="{Binding LoadFactor}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="5" Text="RPM Vibration" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding EngineVibrationEnabled, Mode=TwoWay}"/>
                            <Slider Grid.Row="5" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding EngineVibrationStrengthPercent, Mode=TwoWay}"/>
                            <ComboBox Grid.Row="5" Grid.Column="3"
                                      ItemsSource="{Binding CurveKinds}"
                                      SelectedItem="{Binding EngineVibrationCurve, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="5" Grid.Column="4" Classes="output" Text="{Binding EngineVibrationOutput}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="6" Text="Surface Feedback" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding SurfaceFeedbackEnabled, Mode=TwoWay}"/>
                            <Slider Grid.Row="6" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding SurfaceFeedbackStrengthPercent, Mode=TwoWay}"/>
                            <ComboBox Grid.Row="6" Grid.Column="3"
                                      ItemsSource="{Binding CurveKinds}"
                                      SelectedItem="{Binding SurfaceFeedbackCurve, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="6" Grid.Column="4" Classes="output" Text="{Binding SurfaceFeedbackOutput}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="7" Text="Slip Feedback" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="7" Grid.Column="1" IsChecked="{Binding SlipFeedbackEnabled, Mode=TwoWay}"/>
                            <Slider Grid.Row="7" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding SlipFeedbackStrengthPercent, Mode=TwoWay}"/>
                            <ComboBox Grid.Row="7" Grid.Column="3"
                                      ItemsSource="{Binding CurveKinds}"
                                      SelectedItem="{Binding SlipFeedbackCurve, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="7" Grid.Column="4" Classes="output" Text="{Binding SlipFeedbackOutput}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="8" Text="Wetness" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding WetnessFeedbackEnabled, Mode=TwoWay}"/>
                            <Slider Grid.Row="8" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding WetnessFeedbackStrengthPercent, Mode=TwoWay}"/>
                            <ComboBox Grid.Row="8" Grid.Column="3"
                                      ItemsSource="{Binding CurveKinds}"
                                      SelectedItem="{Binding WetnessFeedbackCurve, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="8" Grid.Column="4" Classes="output" Text="{Binding WetnessFeedbackOutput}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="9" Text="Motion" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="9" Grid.Column="1" IsChecked="{Binding MotionFeedbackEnabled, Mode=TwoWay}"/>
                            <Slider Grid.Row="9" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding MotionFeedbackStrengthPercent, Mode=TwoWay}"/>
                            <ComboBox Grid.Row="9" Grid.Column="3"
                                      ItemsSource="{Binding CurveKinds}"
                                      SelectedItem="{Binding MotionFeedbackCurve, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="9" Grid.Column="4" Classes="output" Text="{Binding DamperOutput}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="10" Text="Bump" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="10" Grid.Column="1" IsChecked="{Binding BumpFeedbackEnabled, Mode=TwoWay}"/>
                            <Slider Grid.Row="10" Grid.Column="2" Minimum="0" Maximum="100" TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding BumpFeedbackStrengthPercent, Mode=TwoWay}"/>
                            <ComboBox Grid.Row="10" Grid.Column="3"
                                      ItemsSource="{Binding CurveKinds}"
                                      SelectedItem="{Binding BumpFeedbackCurve, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="10" Grid.Column="4" Classes="output" Text="{Binding BumpFeedbackOutput}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Logs">
                <Border Classes="panel" Margin="0,16,0,0">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,12">
                            <TextBlock Classes="section" Text="Event Log"/>
                            <TextBlock Classes="muted" Text="{Binding LogPath}"/>
                        </StackPanel>
                        <ListBox Classes="logList"
                                 ItemsSource="{Binding Logs}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Classes="logLine" Text="{Binding}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
